# Production environment variables
# Copy this file to .env and fill in the values.
# Never commit real secrets to GitHub.

# JWT secret for authentication (generate: openssl rand -hex 32)
JWT_SECRET=replace-with-a-random-32-byte-secret

# OpenRouter API key for AI features
OPENROUTER_API_KEY=

# AI model to use
AI_MODEL=meta-llama/llama-3.1-8b-instruct:free

# CORS origin (your domain — the actual serving domain, not the sub-path)
CORS_ORIGIN=https://your-domain.example

# SFU (mediasoup) configuration
# Public IP of your server (for WebRTC ICE candidates)
ANNOUNCED_IP=203.0.113.10

# UDP port range for mediasoup RTP (must be open in firewall)
SFU_RTC_MIN_PORT=10000
SFU_RTC_MAX_PORT=10100

# Social publishing
# Demo mode keeps the full publish workflow usable without provider approval.
# Set to false only after configuring provider OAuth credentials and upload adapters.
PUBLISH_DEMO_MODE=true
PUBLIC_BASE_URL=https://your-domain.example

# YouTube upload API
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=https://your-domain.example/meet/api/publish/oauth/youtube/callback

# Douyin Open Platform
DOUYIN_CLIENT_KEY=
DOUYIN_CLIENT_SECRET=
DOUYIN_REDIRECT_URI=https://your-domain.example/meet/api/publish/oauth/douyin/callback

# Xiaohongshu Open Platform
XIAOHONGSHU_CLIENT_ID=
XIAOHONGSHU_CLIENT_SECRET=
XIAOHONGSHU_REDIRECT_URI=https://your-domain.example/meet/api/publish/oauth/xiaohongshu/callback

# WeChat Channels / Video Account
WECHAT_CHANNELS_APP_ID=
WECHAT_CHANNELS_APP_SECRET=
WECHAT_CHANNELS_REDIRECT_URI=https://your-domain.example/meet/api/publish/oauth/wechat/callback
