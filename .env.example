# ScreenFlow AI - Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ⚠️ IMPORTANT: Never commit .env.local to version control!
# The .env.local file is already in .gitignore

# ==================================================
# OpenRouter API Configuration
# ==================================================

# Get your API key from: https://openrouter.ai/keys
# The variable MUST start with VITE_ for Vite to expose it to the browser
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# ==================================================
# AI Model Selection
# ==================================================

# Free models (no API credits required):
# - meta-llama/llama-3.1-8b-instruct:free (Recommended for testing)
# - google/gemini-2.0-flash-exp:free (Alternative, may have daily limits)
# - mistralai/mistral-7b-instruct:free (Alternative)
#
# Paid models (requires API credits):
# - openai/gpt-4o-mini (Recommended - Fast, reliable, ~$0.005 per request)
# - anthropic/claude-3-5-haiku (Very fast - ~$0.003 per request)
# - google/gemini-flash-1.5 (High quality - ~$0.01 per request)

VITE_AI_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ==================================================
# Notes
# ==================================================

# 1. Free models are great for testing and development
# 2. Paid models offer better quality and no rate limits
# 3. You can switch models anytime by changing VITE_AI_MODEL
# 4. Restart the dev server after changing environment variables
