generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  avatar    String?
  role      String   @default("STUDENT")
  createdAt DateTime @default(now())
}

model Room {
  id          String   @id @default(cuid())
  meetingId   String   @unique
  name        String
  hostId      String
  password    String?
  isRecording Boolean  @default(false)
  createdAt   DateTime @default(now())
  messages    ChatMessage[]
  recordings  Recording[]
  polls       Poll[]
  summaries   MeetingSummary[]
  recordingsMeta RecordingMetadata[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  content   String
  userId    String
  userName  String
  roomId    String
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model Recording {
  id        String   @id @default(cuid())
  roomId    String
  url       String
  duration  Int
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model Poll {
  id        String   @id @default(cuid())
  roomId    String
  question  String
  options   String
  isActive  Boolean  @default(true)
  createdBy String
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  votes     Vote[]
}

model Vote {
  id        String   @id @default(cuid())
  pollId    String
  userId    String
  userName  String
  optionIdx Int
  createdAt DateTime @default(now())
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
}

model MeetingSummary {
  id         String   @id @default(cuid())
  roomId     String
  content    String
  transcript String
  createdAt  DateTime @default(now())
  room       Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

model RecordingMetadata {
  id          String   @id @default(cuid())
  roomId      String
  userId      String
  userName    String
  fileName    String
  fileSize    Int
  duration    Int
  mimeType    String
  storagePath String?
  createdAt   DateTime @default(now())
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
}
