# Server Configuration
PORT=4000
NODE_ENV=development

# Database (SQLite for development, PostgreSQL for production)
DATABASE_URL="file:./dev.db"

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this

# OpenRouter API Key (moved from frontend for security)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# AI Model
AI_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Social publishing
PUBLISH_DEMO_MODE=true
PUBLIC_BASE_URL=http://localhost:4000

YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:4000/api/publish/oauth/youtube/callback

DOUYIN_CLIENT_KEY=
DOUYIN_CLIENT_SECRET=
DOUYIN_REDIRECT_URI=http://localhost:4000/api/publish/oauth/douyin/callback

XIAOHONGSHU_CLIENT_ID=
XIAOHONGSHU_CLIENT_SECRET=
XIAOHONGSHU_REDIRECT_URI=http://localhost:4000/api/publish/oauth/xiaohongshu/callback

WECHAT_CHANNELS_APP_ID=
WECHAT_CHANNELS_APP_SECRET=
WECHAT_CHANNELS_REDIRECT_URI=http://localhost:4000/api/publish/oauth/wechat/callback
